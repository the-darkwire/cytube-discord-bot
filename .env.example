# Required: Discord bot auth token (from the Developer Portal).
DISCORD_TOKEN=

# Required for `pnpm deploy-commands` (one-time slash-command registration).
# Not required at runtime — the bot reads its own user ID from Discord after login.
DISCORD_CLIENT_ID=

# Legacy (optional): if set on first boot AND no subscriptions are persisted yet,
# the bot will seed one subscription from these. Used for migrating the older
# single-tenant env-based config into the new JSON store. Safe to remove after
# the first successful boot.
CYTUBE_CHANNEL=
DISCORD_CHANNEL_ID=
